# Environment Variables & Credentials Template
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to git (it's in .gitignore)

# ============================================================
# GOOGLE API CREDENTIALS
# ============================================================

# Path to your Google OAuth 2.0 credentials JSON file
# Download from: https://console.cloud.google.com/
# Save the file as: backend/credentials.json
# This file will be created automatically by the app on first auth
GOOGLE_CREDENTIALS_FILE=credentials.json

# After first authentication, token.json will be created here
# This is auto-generated, do NOT edit manually
GOOGLE_TOKEN_FILE=token.json

# Google OAuth Scopes (read-only, don't change)
GOOGLE_SCOPES=https://www.googleapis.com/auth/gmail.send,https://www.googleapis.com/auth/calendar

# ============================================================
# OLLAMA SETTINGS
# ============================================================

# Ollama server URL (local by default)
OLLAMA_BASE_URL=http://localhost:11434

# Model names to use
OLLAMA_LLM_MODEL=gemma3:1b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ============================================================
# FASTAPI BACKEND
# ============================================================

# Backend server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# CORS allowed origins (frontend URL)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# VECTOR DATABASE
# ============================================================

# Path to vector database
VECTOR_DB_PATH=./vector_db

# Path to professional profile data
DATA_PATH=./data/professional_profile.txt

# ============================================================
# OPTIONAL: CUSTOM SETTINGS
# ============================================================

# Set to 'production' to disable debug mode
ENVIRONMENT=development

# Logging level
LOG_LEVEL=INFO
