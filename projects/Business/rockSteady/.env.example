# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Strategic Agent Configuration
AGENT_MAX_ITERATIONS=10
AGENT_TEMPERATURE=0.7
AGENT_TOP_P=0.9
AGENT_CONTEXT_LENGTH=4096

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log

# ========== OPTIONAL: API CREDENTIALS ==========
# Only needed for premium features. Leave as placeholders if not using.

# Google APIs (for Google Docs, Calendar, Search)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_CALENDAR_ID=your-email@gmail.com

# Web Search APIs (choose one)
# Option 1: SerpAPI (https://serpapi.com)
SERPAPI_KEY=your-serpapi-key-here

# Option 2: Google Custom Search (https://programmablesearchengine.google.com)
GOOGLE_SEARCH_API_KEY=your-google-search-api-key-here
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id

# Other Services (optional)
NOTION_API_KEY=your-notion-api-key-here
SLACK_BOT_TOKEN=your-slack-bot-token-here

